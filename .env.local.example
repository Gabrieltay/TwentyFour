# Telegram bot token from @BotFather (keep secret, server-only)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# The short_name of the game registered with @BotFather via /newgame
# Must match exactly what BotFather has on file for @TwentyFourGameBot
TELEGRAM_GAME_SHORT_NAME=twentyfour

# Optional: secret token to verify incoming webhook requests actually come from
# Telegram. Set the same value when calling setWebhook's secret_token param.
TELEGRAM_WEBHOOK_SECRET=

# Public base URL of this deployed app (no trailing slash), e.g. https://twentyfour.example.com
# Used to build the game URL Telegram opens, and must match the URL registered
# with @BotFather for this game.
NEXT_PUBLIC_APP_URL=http://localhost:3000
